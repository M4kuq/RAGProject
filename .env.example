APP_ENV=local
DATABASE_URL=postgresql+psycopg://rag:rag@postgres:5432/rag
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
SESSION_SECRET=change-me-in-local-env
SESSION_COOKIE_NAME=rag_session
CSRF_COOKIE_NAME=rag_csrf
SESSION_TOKEN_BYTES=32
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_MAX_AGE_SECONDS=28800
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TOKEN_BYTES=32
CSRF_PRE_AUTH_MAX_AGE_SECONDS=600
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_LOCK_SECONDS=300
LOGIN_RATE_LIMIT_MAX_KEYS=10000
TRUSTED_PROXY_IPS=[]
STORAGE_ROOT=/app/storage/uploads
UPLOAD_MAX_BYTES=20971520
UPLOAD_ALLOWED_EXTENSIONS=[".pdf",".docx",".txt",".md",".markdown",".csv"]
TEMP_CHAT_TTL_MINUTES=120
JOB_LEASE_SECONDS=300
WORKER_POLL_INTERVAL_MS=1000
WORKER_BATCH_SIZE=1
WORKER_LEASE_SECONDS=300
WORKER_LEASE_RENEW_INTERVAL_SECONDS=60
WORKER_SHUTDOWN_GRACE_SECONDS=30
WORKER_ENABLED_JOB_TYPES=all
WORKER_INSTANCE_NAME=
INGEST_CHUNK_SIZE_TOKENS=512
INGEST_CHUNK_OVERLAP_TOKENS=128
INGEST_MAX_EXTRACTED_TEXT_CHARS=5000000
INGEST_CHUNK_PREVIEW_CHARS=200
LOG_LEVEL=INFO
PII_MASKING_ENABLED=true
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=document_chunks_lmstudio
QDRANT_DISTANCE=Cosine
QDRANT_CREATE_COLLECTION=true
QDRANT_REQUIRED=false
QDRANT_UPSERT_BATCH_SIZE=64
QDRANT_TIMEOUT_SECONDS=5
OLLAMA_URL=http://ollama:11434
OLLAMA_TIMEOUT_SECONDS=180
USE_FAKE_LLM=false
MODEL_NAME=llama3.1
EMBEDDING_PROVIDER=lmstudio
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
EMBEDDING_VECTOR_DIMENSION=768
EMBEDDING_FAKE_DIMENSION=8
EMBEDDING_BATCH_SIZE=32
RETRIEVAL_TOP_K_DEFAULT=20
RETRIEVAL_TOP_K_MAX=20
RERANK_PROVIDER=none
RERANK_TOP_N_DEFAULT=5
RERANK_TOP_N_MAX=5
RERANK_SCORE_MIN=0
RERANK_SCORE_MAX=1
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
SEARCH_SNIPPET_MAX_CHARS=240
ASK_TOP_K_DEFAULT=20
ASK_RERANK_TOP_N_DEFAULT=5
GENERATION_PROVIDER=lmstudio
GENERATION_MODEL_NAME=qwen3.5-9b
GENERATION_MAX_CONTEXT_CHARS=6000
GENERATION_MAX_OUTPUT_CHARS=8000
GENERATION_MAX_OUTPUT_TOKENS=8192
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_TIMEOUT_SECONDS=180
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_TIMEOUT_SECONDS=30
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=30
TRACE_EXPORT_ENABLED=false
TRACE_EXPORT_PROVIDER=none
TRACE_EXPORT_TIMEOUT_SECONDS=3
TRACE_EXPORT_INCLUDE_RETRIEVAL=true
TRACE_EXPORT_INCLUDE_EVALUATION=true
TRACE_EXPORT_INCLUDE_CI_SUMMARY=true
TRACE_EXPORT_INCLUDE_PREVIEWS=false
TRACE_EXPORT_PREVIEW_MAX_CHARS=0
LANGSMITH_TRACING_ENABLED=false
LANGSMITH_PROJECT=ragproject-phase2
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
CITATION_PREVIEW_MAX_CHARS=240
CONFIDENCE_HIGH_THRESHOLD=0.75
CONFIDENCE_MEDIUM_THRESHOLD=0.45
GROUNDEDNESS_HIGH_THRESHOLD=0.75
GROUNDEDNESS_MEDIUM_THRESHOLD=0.45
MCP_ENABLED=true
MCP_TRANSPORT=stdio
MCP_LOCAL_ONLY=true
MCP_ACTOR_MODE=mcp_local
MCP_SNIPPET_MAX_CHARS=240
MCP_TOOL_TIMEOUT_SECONDS=30
MCP_ALLOW_WRITE_TOOLS=false
VITE_API_BASE_URL=
