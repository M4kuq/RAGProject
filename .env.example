APP_ENV=local
# Postgres credentials consumed by docker-compose. They default to "rag" for
# local use; override them (and DATABASE_URL below) for any shared environment.
POSTGRES_DB=rag
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
# DATABASE_URL takes precedence over the POSTGRES_* variables above: when set, it
# is used verbatim as the SQLAlchemy URL by docker-compose. It is REQUIRED if the
# password contains URL-reserved characters (e.g. @ : / # ?), because those break
# the URL that would otherwise be composed from POSTGRES_USER/POSTGRES_PASSWORD.
DATABASE_URL=postgresql+psycopg://rag:rag@postgres:5432/rag
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
SESSION_SECRET=change-me-in-local-env
SESSION_COOKIE_NAME=rag_session
CSRF_COOKIE_NAME=rag_csrf
SESSION_TOKEN_BYTES=32
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_MAX_AGE_SECONDS=28800
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TOKEN_BYTES=32
CSRF_PRE_AUTH_MAX_AGE_SECONDS=600
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_LOCK_SECONDS=300
LOGIN_RATE_LIMIT_MAX_KEYS=10000
TRUSTED_PROXY_IPS=[]
STORAGE_ROOT=/app/storage/uploads
UPLOAD_MAX_BYTES=20971520
UPLOAD_ALLOWED_EXTENSIONS=[".pdf",".docx",".txt",".md",".markdown",".csv",".xlsx",".pptx",".html",".htm",".xml"]
INGEST_OFFICE_MAX_PAGES=200
INGEST_OFFICE_MAX_ROWS_PER_SHEET=5000
INGEST_OFFICE_MAX_CELLS=100000
INGEST_OFFICE_ROWS_PER_CHUNK=25
INGEST_OFFICE_MAX_SLIDES=300
INGEST_HTML_MAX_ELEMENTS=5000
INGEST_XML_MAX_ELEMENTS=5000
DOCUMENT_URL_FETCH_TIMEOUT_SECONDS=10
DOCUMENT_URL_FETCH_MAX_REDIRECTS=3
DOCUMENT_URL_FETCH_MAX_BYTES=5000000
DOCUMENT_URL_FETCH_ALLOWED_SCHEMES=["http","https"]
DOCUMENT_URL_FETCH_ALLOWED_CONTENT_TYPES=["text/html","application/xhtml+xml","text/xml","application/xml","application/rss+xml","application/atom+xml"]
DOCUMENT_URL_FETCH_BLOCK_PRIVATE_IPS=true
DOCUMENT_URL_FETCH_USER_AGENT=RAGProjectBot/Phase2
TEMP_CHAT_TTL_MINUTES=120
JOB_LEASE_SECONDS=300
WORKER_POLL_INTERVAL_MS=1000
WORKER_BATCH_SIZE=1
WORKER_LEASE_SECONDS=300
WORKER_LEASE_RENEW_INTERVAL_SECONDS=60
WORKER_SHUTDOWN_GRACE_SECONDS=30
WORKER_ENABLED_JOB_TYPES=all
WORKER_INSTANCE_NAME=
INGEST_CHUNK_SIZE_TOKENS=512
INGEST_CHUNK_OVERLAP_TOKENS=128
INGEST_MAX_EXTRACTED_TEXT_CHARS=5000000
INGEST_CHUNK_PREVIEW_CHARS=200
LOG_LEVEL=INFO
PII_MASKING_ENABLED=true
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=document_chunks_lmstudio
QDRANT_DISTANCE=Cosine
QDRANT_CREATE_COLLECTION=true
QDRANT_REQUIRED=false
QDRANT_UPSERT_BATCH_SIZE=64
QDRANT_TIMEOUT_SECONDS=5
OLLAMA_URL=http://ollama:11434
OLLAMA_TIMEOUT_SECONDS=180
USE_FAKE_LLM=false
MODEL_NAME=llama3.1
EMBEDDING_PROVIDER=lmstudio
EMBEDDING_MODEL=text-embedding-nomic-embed-text-v1.5
EMBEDDING_VECTOR_DIMENSION=768
EMBEDDING_FAKE_DIMENSION=8
EMBEDDING_BATCH_SIZE=32
RETRIEVAL_TOP_K_DEFAULT=20
RETRIEVAL_TOP_K_MAX=20
RERANK_PROVIDER=none
RERANK_TOP_N_DEFAULT=5
RERANK_TOP_N_MAX=5
RERANK_SCORE_MIN=0
RERANK_SCORE_MAX=1
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RETRIEVAL_CACHE_ENABLED=false
RETRIEVAL_CACHE_NAMESPACE=rag.retrieval
RETRIEVAL_CACHE_TTL_SECONDS=300
GRAPH_RETRIEVAL_ENABLED=true
GRAPH_STORE_PROVIDER=neo4j
GRAPH_RETRIEVAL_MAX_START_ENTITIES=5
GRAPH_RETRIEVAL_MAX_DEPTH=2
GRAPH_RETRIEVAL_MAX_PATHS=20
GRAPH_RETRIEVAL_MAX_RELATIONS_PER_ENTITY=20
GRAPH_RETRIEVAL_MAX_SOURCE_CHUNKS=20
GRAPH_RETRIEVAL_TIMEOUT_MS=3000
GRAPH_RETRIEVAL_FALLBACK_STRATEGY=hybrid
GRAPH_RETRIEVAL_MIN_ENTITY_MATCH_SCORE=0.5
GRAPH_ROUTER_ENABLED=true
GRAPH_ROUTER_MIN_SIGNAL_SCORE=0.5
# Non-secret local development defaults. Override these for shared environments.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me-local
NEO4J_DATABASE=neo4j
NEO4J_CONNECT_TIMEOUT_SECONDS=3
NEO4J_HEALTH_CHECK_ENABLED=true
NEO4J_PROJECTION_ENABLED=true
NEO4J_PROJECTION_CONNECT_RETRY_ATTEMPTS=30
NEO4J_PROJECTION_CONNECT_RETRY_DELAY_SECONDS=2
SEARCH_SNIPPET_MAX_CHARS=240
ASK_TOP_K_DEFAULT=20
ASK_RERANK_TOP_N_DEFAULT=5
ROUTER_ENABLED=true
ROUTER_MODE=llm
ROUTER_LLM_PLANNER_MODEL_NAME=qwen3.5-4b
ROUTER_LLM_PLANNER_TIMEOUT_SECONDS=30
ROUTER_LLM_PLANNER_MAX_OUTPUT_TOKENS=256
ROUTER_ALLOW_AGENTIC_SEARCH=true
ROUTER_ALLOW_AGENTIC_ASK=true
ROUTER_MAX_RETRIEVAL_CALLS=2
ROUTER_MAX_FALLBACK_CALLS=1
ROUTER_FALLBACK_STRATEGY=fallback_dense
GENERATION_PROVIDER=lmstudio
GENERATION_MODEL_NAME=qwen3.5-9b
GENERATION_MAX_CONTEXT_CHARS=6000
GENERATION_MAX_OUTPUT_CHARS=8000
GENERATION_MAX_OUTPUT_TOKENS=8192
# Optional estimated generation pricing override JSON.
# Rates are USD per 1M tokens; estimates only, not billing records.
# Example: {"openai:gpt-5.5":{"input_per_1m":1.25,"output_per_1m":10.0}}
GENERATION_PRICING_OVERRIDES={}
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_API_KEY=lm-studio
LMSTUDIO_TIMEOUT_SECONDS=600
LLM_ORCHESTRATOR_ENABLED=true
LLM_ORCHESTRATOR_MAX_TOOL_CALLS=8
LLM_ORCHESTRATOR_MAX_SEARCH_CALLS=8
LLM_ORCHESTRATOR_TIMEOUT_SECONDS=600
LLM_ORCHESTRATOR_MAX_QUERY_CHARS=500
LLM_ORCHESTRATOR_MAX_TOOL_RESULT_ITEMS=10
LLM_ORCHESTRATOR_MAX_SNIPPET_CHARS=500
LLM_ORCHESTRATOR_ALLOW_TRACE_INSPECTION=true
LLM_ORCHESTRATOR_ALLOW_ADMIN_TOOLS=false
LANGCHAIN_AGENTIC_ENABLED=true
LANGCHAIN_AGENTIC_MAX_TOOL_CALLS=8
LANGCHAIN_AGENTIC_MAX_SEARCH_CALLS=8
LANGCHAIN_AGENTIC_TIMEOUT_SECONDS=600
LANGCHAIN_AGENTIC_MAX_QUERY_CHARS=500
LANGCHAIN_AGENTIC_MAX_TOOL_RESULT_ITEMS=10
LANGCHAIN_AGENTIC_MAX_SNIPPET_CHARS=500
LANGCHAIN_AGENTIC_ALLOW_ADMIN_TOOLS=false
LANGGRAPH_AGENTIC_ENABLED=true
LANGGRAPH_AGENTIC_MAX_TOOL_CALLS=8
LANGGRAPH_AGENTIC_MAX_SEARCH_CALLS=8
LANGGRAPH_AGENTIC_TIMEOUT_SECONDS=600
LANGGRAPH_AGENTIC_MAX_QUERY_CHARS=500
LANGGRAPH_AGENTIC_MAX_TOOL_RESULT_ITEMS=10
LANGGRAPH_AGENTIC_MAX_SNIPPET_CHARS=500
LANGGRAPH_AGENTIC_ALLOW_ADMIN_TOOLS=false
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_TIMEOUT_SECONDS=30
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_VERSION=2023-06-01
ANTHROPIC_TIMEOUT_SECONDS=30
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_TIMEOUT_SECONDS=30
TRACE_EXPORT_ENABLED=false
TRACE_EXPORT_PROVIDER=none
TRACE_EXPORT_TIMEOUT_SECONDS=3
TRACE_EXPORT_INCLUDE_RETRIEVAL=true
TRACE_EXPORT_INCLUDE_EVALUATION=true
TRACE_EXPORT_INCLUDE_CI_SUMMARY=true
TRACE_EXPORT_INCLUDE_PREVIEWS=false
TRACE_EXPORT_PREVIEW_MAX_CHARS=0
LANGSMITH_TRACING_ENABLED=false
LANGSMITH_PROJECT=ragproject-phase2
LANGSMITH_ENDPOINT=
LANGSMITH_API_KEY=
CITATION_PREVIEW_MAX_CHARS=240
CONFIDENCE_HIGH_THRESHOLD=0.75
CONFIDENCE_MEDIUM_THRESHOLD=0.45
GROUNDEDNESS_HIGH_THRESHOLD=0.75
GROUNDEDNESS_MEDIUM_THRESHOLD=0.45
MCP_ENABLED=true
MCP_TRANSPORT=stdio
MCP_LOCAL_ONLY=true
MCP_ACTOR_MODE=mcp_local
MCP_SNIPPET_MAX_CHARS=240
MCP_TOOL_TIMEOUT_SECONDS=30
MCP_ALLOW_WRITE_TOOLS=false
MCP_ENABLE_ADVANCED_RAG_TOOLS=true
MCP_ALLOWED_STRATEGIES=dense,sparse,hybrid,agentic_router,llm_tool_orchestrator,langchain_agentic,langgraph_agentic
MCP_INCLUDE_TRACE_SUMMARY_DEFAULT=false
MCP_MAX_ANSWER_CHARS=4000
MCP_ALLOW_EVALUATION_RUN_CREATE=false
VITE_API_BASE_URL=
