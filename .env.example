APP_ENV=local
DATABASE_URL=postgresql+psycopg://rag:rag@postgres:5432/rag
CORS_ALLOWED_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]
SESSION_SECRET=change-me-in-local-env
SESSION_COOKIE_NAME=rag_session
CSRF_COOKIE_NAME=rag_csrf
SESSION_TOKEN_BYTES=32
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAMESITE=lax
SESSION_COOKIE_MAX_AGE_SECONDS=28800
CSRF_HEADER_NAME=X-CSRF-Token
CSRF_TOKEN_BYTES=32
CSRF_PRE_AUTH_MAX_AGE_SECONDS=600
LOGIN_RATE_LIMIT_WINDOW_SECONDS=300
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=5
LOGIN_RATE_LIMIT_LOCK_SECONDS=300
LOGIN_RATE_LIMIT_MAX_KEYS=10000
TRUSTED_PROXY_IPS=[]
STORAGE_ROOT=/app/storage/uploads
UPLOAD_MAX_BYTES=20971520
UPLOAD_ALLOWED_EXTENSIONS=[".pdf",".docx",".txt",".md",".csv"]
TEMP_CHAT_TTL_MINUTES=120
JOB_LEASE_SECONDS=300
LOG_LEVEL=INFO
PII_MASKING_ENABLED=true
QDRANT_URL=http://qdrant:6333
OLLAMA_URL=http://ollama:11434
USE_FAKE_LLM=false
MODEL_NAME=llama3.1
EMBEDDING_MODEL=BAAI/bge-m3
RERANKER_MODEL=BAAI/bge-reranker-v2-m3
VITE_API_BASE_URL=
